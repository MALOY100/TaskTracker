<Window x:Class="TaskTracker.Desktop.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 Статистика" Height="350" Width="400">
    <StackPanel Margin="20">
        <TextBlock Text="Статистика задач" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
        <TextBlock x:Name="TotalText" FontSize="16" Margin="0,5"/>
        <TextBlock x:Name="TodoText" FontSize="16" Margin="0,5"/>
        <TextBlock x:Name="ProgressText" FontSize="16" Margin="0,5"/>
        <TextBlock x:Name="DoneText" FontSize="16" Margin="0,5"/>
        <TextBlock x:Name="OverdueText" FontSize="16" Margin="0,5" Foreground="Red"/>
        <Button Content="Обновить" Click="Refresh_Click" Margin="0,30,0,0" Height="35"/>
    </StackPanel>
</Window>