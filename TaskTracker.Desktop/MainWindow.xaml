<Window x:Class="TaskTracker.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Трекер задач" Height="550" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="📋 Трекер задач" FontSize="24" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>

        <!-- Канбан-доска - 3 колонки -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Колонка TO DO -->
            <Border Grid.Column="0" Background="#FFF0F0F0" Margin="5" Padding="5" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text=" TO DO" FontSize="16" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,10"/>
                    <ListBox x:Name="TodoList" Grid.Row="1" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="5" Margin="0,2" Padding="5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Deadline, StringFormat='dd.MM.yyyy'}" FontSize="10" Foreground="{Binding DeadlineColor}"/>
                                        <Button Content="▶ В работу" Click="MoveToProgress_Click" Tag="{Binding Id}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Колонка IN PROGRESS -->
            <Border Grid.Column="1" Background="#FFF0F0F0" Margin="5" Padding="5" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text=" IN PROGRESS" FontSize="16" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,10"/>
                    <ListBox x:Name="ProgressList" Grid.Row="1" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="5" Margin="0,2" Padding="5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                        <Button Content="✓ Завершить" Click="MoveToDone_Click" Tag="{Binding Id}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Колонка DONE -->
            <Border Grid.Column="2" Background="#FFF0F0F0" Margin="5" Padding="5" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text=" DONE" FontSize="16" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,10"/>
                    <ListBox x:Name="DoneList" Grid.Row="1" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#E8F5E9" CornerRadius="5" Margin="0,2" Padding="5">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Панель добавления задач -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBox x:Name="TitleBox" Width="300" Margin="0,0,10,0" Height="35" FontSize="14" ToolTip="Название задачи"/>
            <DatePicker x:Name="DeadlinePicker" Width="120" Margin="0,0,10,0"/>
            <Button x:Name="AddButton" Content=" Добавить задачу" Width="130" Height="35" Click="AddButton_Click" FontSize="12"/>
            <Button x:Name="RefreshButton" Content=" Обновить" Width="100" Height="35" Click="RefreshButton_Click" FontSize="12" Margin="10,0,0,0"/>
            <Button Content="📊 Статистика" Width="100" Height="35" Click="Statistics_Click" FontSize="12" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>